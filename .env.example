# Supabase
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Maps (Places API v2)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Yelp Fusion API
YELP_API_KEY=your-yelp-api-key

# Scraper settings
TARGET_STATES=AL,AK,AZ,AR,CA,CO,CT,DE,FL,GA,HI,ID,IL,IN,IA,KS,KY,LA,ME,MD,MA,MI,MN,MS,MO,MT,NE,NV,NH,NJ,NM,NY,NC,ND,OH,OK,OR,PA,RI,SC,SD,TN,TX,UT,VT,VA,WA,WV,WI,WY
# Override which states to scrape this run (optional):
# SCRAPE_STATES=TX,GA

# Safe mode: limits API usage for testing (1=on, 0=off)
SAFE_MODE=0
SAFE_MODE_MAX_STATES=1
SAFE_MODE_MAX_QUERIES=2
SAFE_MODE_MAX_RESULTS=10

# Live discovery query expansion suffixes (comma-separated)
LIVE_SEARCH_TERM_SUFFIXES=unreliable internet,slow internet speeds,high internet cost,backup internet,rural connectivity

# Contact enrichment
CONTACT_ENRICHMENT_ENABLED=true
CONTACT_ENRICH_PROVIDER=custom
CONTACT_ENRICH_API_KEY=your-contact-enrichment-api-key
CONTACT_ENRICH_API_BASE_URL=https://your-enrichment-provider.example.com
CONTACT_ENRICH_TIMEOUT_MS=12000
CONTACT_ENRICH_MAX_CONTACTS_PER_LEAD=5
CONTACT_ENRICH_MIN_CONFIDENCE=55

# Public website crawl fallback
CONTACT_WEBSITE_CRAWL_ENABLED=true
CONTACT_WEBSITE_CRAWL_MAX_PAGES=6
CONTACT_WEBSITE_CRAWL_TIMEOUT_MS=8000
CONTACT_WEBSITE_CRAWL_USER_AGENT=VetElecTechLeadFinderBot/1.0

# Enrichment throughput
CONTACT_RATE_LIMIT_PER_MIN=45
CONTACT_BATCH_SIZE=15
CONTACT_BATCH_MAX_LEADS=150

# Include company-level profile URLs when discovered
CONTACT_INCLUDE_LINKEDIN_COMPANY=true
CONTACT_INCLUDE_FACEBOOK_PAGE=true
CONTACT_INCLUDE_INDEED_COMPANY=true

# UI branding (optional)
VITE_CONTACT_EMAIL=you@example.com
VITE_APP_ATTRIBUTION=VetElecTech.com

# Scoring weights (must sum to 100)
SCORE_CRITICALITY=35
SCORE_INDUSTRY=25
SCORE_AREA=20
SCORE_VIABILITY=15
SCORE_ACCESSIBILITY=5
